{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:allow-read-text-file",
    "fs:allow-read-text-file-lines",
    "fs:allow-read-dir",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$HOME/.claude/**" }, { "path": "$HOME/Projects/**" }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "gh", "cmd": "gh", "args": true },
        { "name": "claude", "cmd": "claude", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "gh", "cmd": "gh", "args": true },
        { "name": "claude", "cmd": "claude", "args": true }
      ]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write"
  ]
}
